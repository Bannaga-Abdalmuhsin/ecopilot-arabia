modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/ecopilot-video: web"

[[workflows.workflow]]
name = "artifacts/ecopilot-video: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5174 BASE_PATH=/ecopilot-video pnpm --filter @workspace/ecopilot-video run dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
